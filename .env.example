# ================================================================
# SCPro LinkedIn Co-Pilot — Environment Variables
# Copy this file to .env and fill in your values
# ================================================================

# ---------------------------------------------------------------
# GROQ API KEY (required)
# Get free key from: https://console.groq.com/keys
# Key starts with: gsk_
# ---------------------------------------------------------------
GROQ_API_KEY=gsk_your_key_here

# ---------------------------------------------------------------
# WHATSAPP — CallMeBot (optional but recommended)
# Step 1: Add +34 644 91 71 62 to your WhatsApp contacts
# Step 2: Send this exact message to them: "I allow callmebot to send me messages"
# Step 3: You'll receive your API key back via WhatsApp
# Phone format: country code + number, NO + sign (e.g. 971501234567)
# ---------------------------------------------------------------
WA_PHONE=971501234567
WA_APIKEY=1234567

# ---------------------------------------------------------------
# EMAIL — Gmail App Password (optional)
# Step 1: Enable 2FA on your Google account
# Step 2: Go to myaccount.google.com/apppasswords
# Step 3: Create app password for "Mail"
# Step 4: Use the 16-character password (no spaces) below
# ---------------------------------------------------------------
EMAIL_FROM=yourname@gmail.com
EMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_TO=yourname@gmail.com

# ---------------------------------------------------------------
# POST SCHEDULE — when to auto-generate daily posts
# Default: 0 5 * * * = 5AM UTC = 9AM UAE time (daily)
# Cron format: minute hour day month weekday
# ---------------------------------------------------------------
POST_SCHEDULE=0 5 * * *

# ---------------------------------------------------------------
# RENDER — your deployed backend URL (for self-ping keep-alive)
# Set this AFTER you deploy to Render
# Format: https://your-app-name.onrender.com
# ---------------------------------------------------------------
RENDER_EXTERNAL_URL=https://your-app-name.onrender.com

# ---------------------------------------------------------------
# PORT (Render sets this automatically, don't change)
# ---------------------------------------------------------------
PORT=3000
